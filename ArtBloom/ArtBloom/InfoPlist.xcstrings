      }
    },
    "NSPhotoLibraryUsageDescription" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ArtBloom needs access to your photos to import images for drawing and style transformation."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "艺绽需要访问您的照片，以便导入图片进行绘画和风格转换。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "藝綻需要存取您的照片，以便匯入圖片進行繪畫和風格轉換。"
          }
        }
      }
    },
    "NSUserTrackingUsageDescription" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ArtBloom uses your device identifier to measure ad performance and improve your experience."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "艺绽会使用设备标识符衡量广告效果并优化您的使用体验。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "藝綻會使用裝置識別碼衡量廣告效果並優化您的使用體驗。"
          }
        }
      }
    }
  },
  "version" : "1.0"
}
